<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="/Users/jacobsmith/Desktop/fitness_marketing_analysis/data/marketing.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="3543"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="campaign_daily" custom_title="0" dock_id="2" table="4,14:maincampaign_daily"/><dock_state state="000000ff00000000fd0000000100000002000004de0000021dfc0100000002fb000000160064006f0063006b00420072006f00770073006500310100000000ffffffff0000000000000000fb000000160064006f0063006b00420072006f00770073006500320100000000000004de0000011f00ffffff000002900000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="campaign_daily" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="69"/><column index="2" value="92"/><column index="3" value="68"/><column index="4" value="65"/><column index="5" value="99"/><column index="6" value="87"/><column index="7" value="46"/><column index="8" value="65"/><column index="9" value="87"/><column index="10" value="76"/><column index="11" value="72"/><column index="12" value="46"/><column index="13" value="60"/><column index="14" value="122"/><column index="15" value="122"/><column index="16" value="116"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">-- 1) Monthly rollup by channel + segment
DROP VIEW IF EXISTS v_monthly_channel_segment;

CREATE VIEW v_monthly_channel_segment AS
SELECT
  substr(date, 1, 7) AS month,
  channel,
  segment,
  SUM(impressions) AS impressions,
  SUM(clicks) AS clicks,
  SUM(sessions) AS sessions,
  SUM(add_to_cart) AS add_to_cart,
  SUM(purchases) AS purchases,
  SUM(ad_spend) AS ad_spend,
  SUM(revenue) AS revenue,
  AVG(discount_rate) AS avg_discount
FROM campaign_daily
GROUP BY 1, 2, 3;

-- 2) KPI view 
DROP VIEW IF EXISTS v_monthly_kpis;

CREATE VIEW v_monthly_kpis AS
SELECT
  month,
  channel,
  segment,
  impressions,
  clicks,
  sessions,
  add_to_cart,
  purchases,
  ad_spend,
  revenue,
  avg_discount,
  CASE WHEN impressions &gt; 0 THEN CAST(clicks AS REAL) / impressions END AS ctr,
  CASE WHEN sessions &gt; 0 THEN CAST(purchases AS REAL) / sessions END AS cvr,
  CASE WHEN purchases &gt; 0 THEN ad_spend / purchases END AS cpa,
  CASE WHEN ad_spend &gt; 0 THEN revenue / ad_spend END AS roas,
  (revenue - ad_spend) AS profit_proxy
FROM v_monthly_channel_segment;

-- 3) Channel summary across full year 
DROP VIEW IF EXISTS v_channel_summary;

CREATE VIEW v_channel_summary AS
SELECT
  channel,
  SUM(impressions) AS impressions,
  SUM(clicks) AS clicks,
  SUM(sessions) AS sessions,
  SUM(purchases) AS purchases,
  SUM(ad_spend) AS ad_spend,
  SUM(revenue) AS revenue,
  CASE WHEN SUM(impressions) &gt; 0 THEN CAST(SUM(clicks) AS REAL) / SUM(impressions) END AS ctr,
  CASE WHEN SUM(sessions) &gt; 0 THEN CAST(SUM(purchases) AS REAL) / SUM(sessions) END AS cvr,
  CASE WHEN SUM(purchases) &gt; 0 THEN SUM(ad_spend) / SUM(purchases) END AS cpa,
  CASE WHEN SUM(ad_spend) &gt; 0 THEN SUM(revenue) / SUM(ad_spend) END AS roas,
  (SUM(revenue) - SUM(ad_spend)) AS profit_proxy
FROM campaign_daily
GROUP BY 1
ORDER BY profit_proxy DESC; 

SELECT name FROM sqlite_master WHERE type='table';
SELECT COUNT(*) FROM campaign_daily;
SELECT * FROM v_channel_summary;

SELECT
  channel,
  segment,
  SUM(purchases) AS purchases,
  SUM(ad_spend) AS spend,
  SUM(revenue) AS revenue,
  CASE WHEN SUM(ad_spend) &gt; 0 THEN SUM(revenue) / SUM(ad_spend) END AS roas
FROM campaign_daily
GROUP BY channel, segment
ORDER BY channel, segment;

SELECT
  channel,
  SUM(revenue) AS revenue,
  SUM(ad_spend) AS spend,
  ROUND(SUM(revenue) * 0.60 - SUM(ad_spend), 0) AS gross_profit_estimate
FROM campaign_daily
GROUP BY channel
ORDER BY gross_profit_estimate DESC;

SELECT
  channel,
  SUM(CASE WHEN segment = 'New' THEN purchases END) AS new_purchases,
  SUM(CASE WHEN segment = 'New' THEN ad_spend END) AS new_spend,
  ROUND(
    SUM(CASE WHEN segment = 'New' THEN ad_spend END) /
    SUM(CASE WHEN segment = 'New' THEN purchases END),
    2
  ) AS new_cac
FROM campaign_daily
GROUP BY channel
ORDER BY new_cac;

SELECT
  channel,
  ROUND(SUM(ad_spend), 0) AS total_spend
FROM campaign_daily
GROUP BY channel
ORDER BY total_spend DESC;</sql><current_tab id="0"/></tab_sql></sqlb_project>
